class DCGANGenerator(nn.Module):
    def __init__(self, z_dim, channels, features_g):
        super().__init__()
        self.net = nn.Sequential(
            
            self._block(z_dim, features_g*8, 4, 1, 0),
            self._block(features_g*8, features_g*4, 4, 2, 1),
            self._block(features_g*4, features_g*2, 4, 2, 1),
            self._block(features_g*2, features_g, 4, 2, 1),
            nn.ConvTranspose2d(features_g, channels, 4, 2, 1),
            nn.Tanh()
        )
    
    def _block(self, in_c, out_c, k, s, p):
        return nn.Sequential(
            nn.ConvTranspose2d(in_c, out_c, k, s, p, bias=False),
            nn.BatchNorm2d(out_c),
            nn.ReLU(True)
        )
    
    def forward(self, x):
        return self.net(x)

print("DCGAN Generator defined ")



class DCGANDiscriminator(nn.Module):
    def __init__(self, channels, features_d):
        super().__init__()
        self.net = nn.Sequential(
            # Input: channels x 64 x 64
            nn.Conv2d(channels, features_d, 4, 2, 1, bias=False),
            nn.LeakyReLU(0.2, inplace=True),
            self._block(features_d, features_d*2, 4, 2, 1),
            self._block(features_d*2, features_d*4, 4, 2, 1),
            self._block(features_d*4, features_d*8, 4, 2, 1),
            nn.Conv2d(features_d*8, 1, 4, 1, 0),
            nn.Sigmoid()
        )
    
    def _block(self, in_c, out_c, k, s, p):
        return nn.Sequential(
            nn.Conv2d(in_c, out_c, k, s, p, bias=False),
            nn.BatchNorm2d(out_c),
            nn.LeakyReLU(0.2, inplace=True)
        )
    
    def forward(self, x):
        return self.net(x).view(-1, 1)

print("DCGAN Discriminator defined ")



netG_dcgan = DCGANGenerator(Z_DIM, CHANNELS, FEATURES_G).to(device)
netD_dcgan = DCGANDiscriminator(CHANNELS, FEATURES_D).to(device)

def weights_init(m):
    classname = m.__class__.__name__
    if classname.find('Conv') != -1:
        nn.init.normal_(m.weight.data, 0.0, 0.02)
    elif classname.find('BatchNorm') != -1:
        nn.init.normal_(m.weight.data, 1.0, 0.02)
        nn.init.constant_(m.bias.data, 0)

netG_dcgan.apply(weights_init)
netD_dcgan.apply(weights_init)

optimizer_G_dcgan = optim.Adam(netG_dcgan.parameters(), lr=LR, betas=BETAS)
optimizer_D_dcgan = optim.Adam(netD_dcgan.parameters(), lr=LR, betas=BETAS)

criterion = nn.BCELoss()

print("DCGAN Models initialized ")
print(f"Generator parameters: {sum(p.numel() for p in netG_dcgan.parameters()):,}")
print(f"Discriminator parameters: {sum(p.numel() for p in netD_dcgan.parameters()):,}")





def train_dcgan(num_epochs):
    G_losses = []
    D_losses = []
    
    print("Starting DCGAN Training...")
    
    for epoch in range(num_epochs):
        epoch_G_loss = 0
        epoch_D_loss = 0
        
        for i, real_images in enumerate(dataloader):
            real_images = real_images.to(device)
            batch_size = real_images.size(0)
            
            real_labels = torch.ones(batch_size, 1).to(device)
            fake_labels = torch.zeros(batch_size, 1).to(device)
            
            optimizer_D_dcgan.zero_grad()
            
            output_real = netD_dcgan(real_images)
            loss_D_real = criterion(output_real, real_labels)
            
            noise = torch.randn(batch_size, Z_DIM, 1, 1).to(device)
            fake_images = netG_dcgan(noise)
            output_fake = netD_dcgan(fake_images.detach())
            loss_D_fake = criterion(output_fake, fake_labels)
            
            loss_D = loss_D_real + loss_D_fake
            loss_D.backward()
            optimizer_D_dcgan.step()
            
            
            optimizer_G_dcgan.zero_grad()
            
            output = netD_dcgan(fake_images)
            loss_G = criterion(output, real_labels)
            loss_G.backward()
            optimizer_G_dcgan.step()
            
            epoch_G_loss += loss_G.item()
            epoch_D_loss += loss_D.item()
        
        avg_G_loss = epoch_G_loss / len(dataloader)
        avg_D_loss = epoch_D_loss / len(dataloader)
        
        G_losses.append(avg_G_loss)
        D_losses.append(avg_D_loss)
        
        if (epoch + 1) % 5 == 0:
            print(f"Epoch [{epoch+1}/{num_epochs}] | D Loss: {avg_D_loss:.4f} | G Loss: {avg_G_loss:.4f}")
            
            with torch.no_grad():
                fake = netG_dcgan(torch.randn(16, Z_DIM, 1, 1).to(device))
                grid = make_grid(fake[:16], padding=2, normalize=True)
                plt.figure(figsize=(8, 8))
                plt.imshow(grid.permute(1, 2, 0).cpu())
                plt.title(f"DCGAN - Epoch {epoch+1}")
                plt.axis('off')
                plt.show()
        
        if (epoch + 1) % SAVE_EVERY == 0:
            torch.save({
                'epoch': epoch,
                'generator': netG_dcgan.state_dict(),
                'discriminator': netD_dcgan.state_dict(),
            }, f'dcgan_checkpoint_epoch_{epoch+1}.pth')
    
    return G_losses, D_losses

print("Training function ready ")



dcgan_G_losses, dcgan_D_losses = train_dcgan(DCGAN_EPOCHS)

print("\n🎉 DCGAN Training Complete ")



plt.figure(figsize=(10, 5))
plt.plot(dcgan_G_losses, label='Generator Loss')
plt.plot(dcgan_D_losses, label='Discriminator Loss')
plt.xlabel('Epoch')
plt.ylabel('Loss')
plt.title('DCGAN Training Losses')
plt.legend()
plt.grid(True)
plt.show()



