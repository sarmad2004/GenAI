def show_generated(generator, z_dim, device, n=16, title="Generated Images"):
    generator.eval()
    with torch.no_grad():
        noise = torch.randn(n, z_dim, 1, 1, device=device)
        fake  = generator(noise).cpu()
    grid = make_grid(fake, nrow=4, normalize=True, padding=2)
    plt.figure(figsize=(8, 8))
    plt.axis("off")
    plt.title(title, fontsize=14)
    plt.imshow(np.transpose(grid, (1, 2, 0)))
    plt.show()
    generator.train()

print("Helper ready ")


class WGANCritic(nn.Module):
    def __init__(self):
        super().__init__()
        self.net = nn.Sequential(
            nn.Conv2d(3, 64, 4, 2, 1, bias=False),
            nn.LeakyReLU(0.2, inplace=True),
            nn.Conv2d(64, 128, 4, 2, 1, bias=False),
            nn.LeakyReLU(0.2, inplace=True),
            nn.Conv2d(128, 256, 4, 2, 1, bias=False),
            nn.LeakyReLU(0.2, inplace=True),
            nn.Conv2d(256, 512, 4, 2, 1, bias=False),
            nn.LeakyReLU(0.2, inplace=True),
            nn.Conv2d(512, 1, 4, 1, 0, bias=False)
        )
    def forward(self, x): return self.net(x).view(x.size(0))

def gradient_penalty(critic, real, fake, device):
    B = real.size(0)
    alpha = torch.rand(B, 1, 1, 1, device=device).expand_as(real)
    interp = (alpha * real + (1 - alpha) * fake).requires_grad_(True)
    d_interp = critic(interp)
    grads = torch.autograd.grad(
        outputs=d_interp, inputs=interp,
        grad_outputs=torch.ones_like(d_interp),
        create_graph=True, retain_graph=True
    )[0]
    grads = grads.view(B, -1)
    return ((grads.norm(2, dim=1) - 1) ** 2).mean()

print("WGAN Critic + Gradient Penalty ready ")


import os
from PIL import Image
from torch.utils.data import Dataset, DataLoader
from torchvision import transforms

class SafeDataset(Dataset):
    def __init__(self, folder, transform=None):
        self.folder = folder
        self.files = [f for f in os.listdir(folder) if f.lower().endswith(('.png', '.jpg', '.jpeg'))]
        self.transform = transform

    def __len__(self): return len(self.files)

    def __getitem__(self, idx):
        img_path = os.path.join(self.folder, self.files[idx])
        img = Image.open(img_path).convert('RGB')
        if self.transform: img = self.transform(img)
        return img, 0

transform = transforms.Compose([
    transforms.Resize((64, 64)),
    transforms.CenterCrop(64),
    transforms.ToTensor(),
    transforms.Normalize([0.5]*3, [0.5]*3),
])

DATA_PATH = '/kaggle/input/datasets/soumikrakshit/anime-faces/data/data'
dataset = SafeDataset(DATA_PATH, transform=transform)

dataloader = DataLoader(dataset, batch_size=64, shuffle=True, num_workers=0, drop_last=True)
print(f" Dataloader ready! Total images: {len(dataset)}")


import time
from torch.cuda.amp import autocast, GradScaler
import torch.optim as optim
import torch.nn as nn

wgan_G = WGANGenerator(100, 3, 64).to(device)
wgan_C = WGANCritic().to(device)

for m in list(wgan_G.modules()) + list(wgan_C.modules()):
    if isinstance(m, (nn.ConvTranspose2d, nn.Conv2d)):
        nn.init.normal_(m.weight.data, 0.0, 0.02)

opt_wG = optim.Adam(wgan_G.parameters(), lr=0.0002, betas=(0.5, 0.999))
opt_wC = optim.Adam(wgan_C.parameters(), lr=0.0002, betas=(0.5, 0.999))
wgan_G_losses, wgan_C_losses = [], []

scaler_C = GradScaler()
scaler_G = GradScaler()

os.makedirs("checkpoints", exist_ok=True)
total_batches = len(dataloader)

print(" Starting WGAN-GP Training...")
for epoch in range(1, WGAN_EPOCHS + 1):
    g_loss_sum = c_loss_sum = 0.0
    start_time = time.time()
    
    for i, batch in enumerate(dataloader):
        real = batch[0].to(device)
        B = real.size(0)
        
        # --- Train Critic 5 times ---
        for _ in range(5):
            opt_wC.zero_grad()
            noise = torch.randn(B, 100, 1, 1, device=device)
            
            with autocast():
                fake = wgan_G(noise).detach()
                c_real = wgan_C(real).mean()
                c_fake = wgan_C(fake).mean()
                
            gp = gradient_penalty(wgan_C, real, fake, device)
            loss_C = -(c_real - c_fake) + 10 * gp
            
            scaler_C.scale(loss_C).backward()
            scaler_C.step(opt_wC)
            scaler_C.update()
            
        opt_wG.zero_grad()
        noise = torch.randn(B, 100, 1, 1, device=device)
        
        with autocast():
            fake_images = wgan_G(noise)
            loss_G = -wgan_C(fake_images).mean()
        
        scaler_G.scale(loss_G).backward()
        scaler_G.step(opt_wG)
        scaler_G.update()
        
        g_loss_sum += loss_G.item()
        c_loss_sum += loss_C.item()
        
        if i % 50 == 0:
            print(f"Epoch [{epoch}/{WGAN_EPOCHS}] Batch [{i}/{total_batches}] | G: {loss_G.item():.4f} | C: {loss_C.item():.4f}")
            
    epoch_time = time.time() - start_time
    avg_G = g_loss_sum / total_batches
    avg_C = c_loss_sum / total_batches
    wgan_G_losses.append(avg_G)
    wgan_C_losses.append(avg_C)
    
    print(f" Epoch {epoch} finished in {epoch_time:.0f} seconds. Avg G: {avg_G:.4f}, Avg C: {avg_C:.4f}")
    
    if epoch % SAVE_EVERY == 0:
        torch.save(wgan_G.state_dict(), f"checkpoints/wgan_G_ep{epoch}.pth")
        show_generated(wgan_G, 100, device, title=f"WGAN-GP Epoch {epoch}")

print(" WGAN-GP Training Complete!")


import matplotlib.pyplot as plt

plt.figure(figsize=(10, 5))
plt.title("WGAN-GP Generator and Critic Loss During Training")
plt.plot(wgan_G_losses, label="Generator Loss")
plt.plot(wgan_C_losses, label="Critic Loss")
plt.xlabel("Epochs")
plt.ylabel("Loss")
plt.legend()
plt.grid(True, alpha=0.3)
plt.show()



